<Window x:Class="AbstractFactory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abstract Factory" Height="350" Width="525">
    <StackPanel>
        <!-- Drop‑down list for colour selection -->
        <ComboBox x:Name="ColorComboBox" SelectionChanged="ColorComboBox_SelectionChanged" Margin="5">
            <ComboBoxItem Content="Красный" />
            <ComboBoxItem Content="Синий" />
            <ComboBoxItem Content="Зелёный" />
        </ComboBox>
        <!-- Area where created figures will be placed -->
        <StackPanel x:Name="FiguresPanel" Orientation="Horizontal" Margin="5" />
    </StackPanel>
</Window>