<Window x:Class="L_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:L_1"
        mc:Ignorable="d"
              Title="Clear" Height="350" Width="525">
    <StackPanel>
        <!-- ComboBox to select a colour. When the selection changes, the handler in the code-behind
             will create new figures of the selected colour. -->
        <ComboBox x:Name="ColorComboBox" SelectionChanged="ColorComboBox_SelectionChanged" Margin="5">
            <ComboBoxItem Content="Красный" />
            <ComboBoxItem Content="Синий" />
            <ComboBoxItem Content="Зелёный" />
        </ComboBox>
        <!-- Panel where the figures will be displayed. Figures are added horizontally. -->
        <StackPanel x:Name="FiguresPanel" Orientation="Horizontal" Margin="5" />
    </StackPanel>
</Window>
